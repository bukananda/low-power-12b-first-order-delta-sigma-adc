C {devices/code_shown.sym} 2021.25 -1073.75 0 0 {name=NGSPICE only_toplevel=true
value="
.lib /foss/pdks/gf180mcuD/libs.tech/ngspice/sm141064.ngspice typical
.inc /foss/pdks/gf180mcuD/libs.tech/ngspice/design.ngspice

.param CL=0.5p
.param Wp=12u Wn=6u Kall=1.28u
.param Wpc=50u Wnc=2u Wsc=2*Wp Lc=10u
.param Wsp=3u Wsn=1.5u Ld=0.3u Wdp=2u Wdn=1u
CLP Vop 0 \{CL\}
CLM Vom 0 \{CL\}
RLEAKP Vop 0 1T
RLEAKM Vom 0 1T

* dummy load supaya tiap node punya DC path ke ground
Rd1 clk1  0 1meg
Rd2 clk2  0 1meg

.control
set color0=white
set color1=black
tran 1u 5u
let vicm_ota = (v(Vp)+v(Vm))/2
let vid_ota  = v(Vp)-v(Vm)
* --- window ala paper ---
*plot v(clk1) v(clk2) v(clk2B)         $ window 1: non-overlapping clocks
*plot v(Vin+) v(Vin-)          $ window 2: input diferensial
*plot v(Vop) v(Vom)            $ window 3: output OTA (single-ended)
*plot v(Vop)-v(Vom)            $ window 4: output integrator (diferensial) -> segitiga
*plot v(Vp) v(Vm)
*plot vicm_ota
*plot vid_ota
plot v(Vout) v(Vin+) v(Vin-)
.endc
.end
"}
